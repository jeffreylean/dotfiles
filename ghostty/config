theme = TokyoNight
font-family = BerkeleyMono Nerd Font

# Window
window-padding-x = 14
window-padding-y = 14
confirm-close-surface=false
resize-overlay = never

# split
# keybind = ctrl+space>c=new_tab
# keybind = ctrl+space>v=new_split:right
# keybind = ctrl+space>s=new_split:down
# keybind = ctrl+space>h=goto_split:left
# keybind = ctrl+space>l=goto_split:right
# keybind = ctrl+space>k=goto_split:top
# keybind = ctrl+space>j=goto_split:bottom
# keybind = ctrl+space>shift+h=resize_split:left,100
# keybind = ctrl+space>shift+l=resize_split:right,100
# keybind = ctrl+space>shift+k=resize_split:up,100
# keybind = ctrl+space>shift+j=resize_split:down,100
# keybind = ctrl+space>z=toggle_split_zoom
keybind = super+k=scroll_page_up
keybind = super+shift+k=scroll_to_top
keybind = super+j=scroll_page_down
keybind = super+shift+j=scroll_to_bottom
keybind = shift+enter=text:\n

# quick terminal access
keybind = super+escape=toggle_quick_terminal

macos-icon = custom-style
macos-icon-ghost-color = #a89984
macos-icon-screen-color = #32302f
macos-icon-frame = beige

# pre-release
auto-update-channel = tip

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll
